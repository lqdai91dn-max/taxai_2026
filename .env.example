# ==========================================
# TaxAI — Environment Variables Template
# Copy to .env and fill in your values
# ==========================================

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Qdrant Cloud (leave empty to use local data/qdrant/)
QDRANT_URL=https://xxxx-xxxx-xxxx.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# App Auth (beta password gate)
APP_PASSWORD=your_beta_password_here
